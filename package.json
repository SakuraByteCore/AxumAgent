{
  "name": "axum-agent",
  "version": "0.1.0",
  "description": "Pi-based coding agent distribution with bundled subagents and Magic Context extensions",
  "license": "MIT",
  "type": "module",
  "bin": {
    "axum": "bin/axum.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build": "node --check bin/axum.js && node --check src/resolve-bundled-pi.js",
    "prepack": "npm run build && npm test",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@cortexkit/pi-magic-context": "0.32.4",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "pi-subagents": "0.35.1"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SakuraByteCore/AxumAgent.git"
  },
  "homepage": "https://github.com/SakuraByteCore/AxumAgent#readme",
  "bugs": {
    "url": "https://github.com/SakuraByteCore/AxumAgent/issues"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "subagents",
    "magic-context",
    "agent",
    "cli"
  ]
}
